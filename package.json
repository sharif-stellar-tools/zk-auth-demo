{
  "name": "zk-auth-demo",
  "version": "1.0.0",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "snarkjs": "^0.5.0"
  },
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharif-stellar-tools/zk-auth-demo.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/snarkjs": "^0.7.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "ts-jest": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "test": "jest",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\"",
    "contract:build": "bash scripts/build.sh",
    "contract:deploy": "bash scripts/deploy.sh",
    "contract:build-and-deploy": "bash scripts/build-and-deploy.sh",
    "contract:optimize": "bash scripts/optimize-wasm.sh",
    "contract:test": "cargo test"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
