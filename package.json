{
  "name": "zk-auth-demo",
  "version": "1.0.0",
  "dependencies": {
    "snarkjs": "^0.5.0"
  },
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sharif-stellar-tools/zk-auth-demo.git"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.tsx\"",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\""
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
